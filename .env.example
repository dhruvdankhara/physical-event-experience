# Firestore project context
GOOGLE_CLOUD_PROJECT_ID=
# Optional Firestore overrides (use if Firestore lives in a different project or non-default database)
FIRESTORE_PROJECT_ID=
FIRESTORE_DATABASE_ID=

# Client Google Maps
GOOGLE_MAPS_API_KEY=

# Auth
AUTH_JWT_SECRET=replace-with-a-long-random-secret
AUTH_COOKIE_NAME=stadium_sync_session
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Google Cloud server-side integrations
GOOGLE_ANALYTICS_PROPERTY_ID=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_VERTEX_MODEL=gemini-2.0-flash-001
GOOGLE_TTS_LANGUAGE_CODE=en-IN
GOOGLE_TTS_VOICE_NAME=en-IN-Standard-B

# Optional when not using workload identity/ADC discovery
GOOGLE_APPLICATION_CREDENTIALS=
