# Database
MONGODB_URI=mongodb://localhost:27017/pee

# Client Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Auth
AUTH_JWT_SECRET=replace-with-a-long-random-secret
AUTH_COOKIE_NAME=stadium_sync_session

# Google Cloud server-side integrations
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_VERTEX_MODEL=gemini-2.0-flash-001
GOOGLE_TTS_LANGUAGE_CODE=en-IN
GOOGLE_TTS_VOICE_NAME=en-IN-Standard-B

# Optional when not using workload identity/ADC discovery
GOOGLE_APPLICATION_CREDENTIALS=
